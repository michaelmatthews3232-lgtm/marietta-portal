# Supabase (create project at supabase.com, free tier)
NEXT_PUBLIC_SUPABASE_URL=https://yourproject.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Netlify (to trigger redeploys from the portal)
NETLIFY_TOKEN=same_token_as_main_project

# Where your generated sites live on this machine
# When deployed, this will be a Supabase storage bucket instead
SITES_DIR=../sites
CLIENTS_DIR=../clients
