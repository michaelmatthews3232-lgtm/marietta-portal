# ============================================================
# REQUIRED — fill every value before deploying
# Copy this file to .env.local for local development
# Add all values as Environment Variables in Vercel for production
# ============================================================

# ---- BRAND & REGIONAL CONFIG ----
# Your agency/brand name (shows in nav, footer, emails)
NEXT_PUBLIC_BRAND_NAME=YourAgencyName

# The city you focus on — used as default in lead searches
NEXT_PUBLIC_DEFAULT_CITY=Atlanta, GA

# Your contact phone number (international format, e.g. +14045550100)
NEXT_PUBLIC_CONTACT_PHONE=+10000000000

# Your contact email shown on the landing page
NEXT_PUBLIC_CONTACT_EMAIL=you@yourdomain.com

# The full URL where this portal is hosted (no trailing slash)
# For local dev: http://localhost:3000
# For production: https://yourapp.vercel.app
NEXT_PUBLIC_PORTAL_URL=https://yourapp.vercel.app


# ---- SUPABASE ----
# Get these from: supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...


# ---- NETLIFY ----
# Get from: app.netlify.com → User Settings → Applications → Personal access tokens
NETLIFY_TOKEN=your_netlify_personal_access_token


# ---- GOOGLE PLACES API ----
# Get from: console.cloud.google.com → APIs & Services → Credentials
# Enable: Places API, Geocoding API
GOOGLE_PLACES_API_KEY=AIza...


# ---- ANTHROPIC (Claude AI) ----
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...


# ---- STRIPE ----
# Get from: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...

# Create two products in Stripe dashboard:
# 1. "Website Setup Fee" — one-time payment, $100 (or your price)
# 2. "Monthly Maintenance" — recurring monthly, $50 (or your price)
# Then copy the Price IDs (start with price_)
STRIPE_SETUP_FEE_PRICE_ID=price_...
STRIPE_MONTHLY_PRICE_ID=price_...

# Webhook secret — get after creating webhook endpoint in Stripe dashboard
# Endpoint URL: https://yourapp.vercel.app/api/stripe-webhook
# Events to listen for: checkout.session.completed, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_...


# ---- ADMIN ACCESS ----
# Comma-separated list of email addresses that have admin access
# These users are redirected to /admin after login instead of /dashboard
ADMIN_EMAILS=you@yourdomain.com,colleague@yourdomain.com

# ---- CALLER ACCESS ----
# Comma-separated list of cold caller emails (Fiverr, etc.)
# These users get /caller — a focused calling dashboard, not full admin
CALLER_EMAILS=yourcaller@email.com
